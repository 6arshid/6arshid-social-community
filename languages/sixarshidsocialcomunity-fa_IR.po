msgstr "اجازه ثبت‌نام"

msgid "Allow new users to register on the social network."
msgstr "به کاربران جدید اجازه ثبت‌نام در شبکه اجتماعی داده شود."

msgid "Relative (e.g. 5 minutes ago)"
msgstr "نسبی (مانند ۵ دقیقه پیش)"

msgid "Absolute (e.g. June 12, 2026)"
msgstr "مطلق (مانند ۲۲ خرداد ۱۴۰۵)"

msgid "Jalali / Persian calendar"
msgstr "تقویم جلالی / شمسی"

msgid "Active Components"
msgstr "اجزای فعال"

msgid "The Members component is always active."
msgstr "اجزای اعضا همیشه فعال است."

msgid "Activity Streams"
msgstr "جریان‌های فعالیت"

msgid "Friends & Follow"
msgstr "دوستان و دنبال کردن"

msgid "Private Messages"
msgstr "پیام‌های خصوصی"

msgid "%s posted an update"
msgstr "%s یک به‌روزرسانی ارسال کرد"

msgid "Security check failed."
msgstr "بررسی امنیتی ناموفق بود."

msgid "You must be logged in."
msgstr "باید وارد سیستم شوید."

msgid "Your account has been suspended."
msgstr "حساب کاربری شما تعلیق شده است."

msgid "You are posting too frequently. Please wait."
msgstr "شما خیلی سریع ارسال می‌کنید. لطفاً صبر کنید."

msgid "Activity content cannot be empty."
msgstr "محتوای فعالیت نمی‌تواند خالی باشد."

msgid "Your post contains prohibited content."
msgstr "پست شما حاوی محتوای ممنوع است."

msgid "Your post was identified as spam."
msgstr "پست شما به عنوان اسپم شناسایی شد."

msgid "Failed to post activity."
msgstr "ارسال فعالیت ناموفق بود."

msgid "Activity posted."
msgstr "فعالیت ارسال شد."

msgid "Activity deleted."
msgstr "فعالیت حذف شد."

msgid "Activity not found."
msgstr "فعالیت یافت نشد."

msgid "Authentication required."
msgstr "احراز هویت لازم است."

msgid "Permission denied."
msgstr "دسترسی رد شد."

msgid "You must be logged in to react."
msgstr "برای واکنش نشان دادن باید وارد سیستم شوید."

msgid "Report submitted. Thank you."
msgstr "گزارش ارسال شد. متشکریم."

msgid "You cannot friend yourself."
msgstr "نمی‌توانید با خود دوست شوید."

msgid "Unable to send friend request."
msgstr "ارسال درخواست دوستی امکان‌پذیر نیست."

msgid "A friend request already exists."
msgstr "درخواست دوستی قبلاً ارسال شده است."

msgid "Friend request sent."
msgstr "درخواست دوستی ارسال شد."

msgid "Friend request accepted."
msgstr "درخواست دوستی پذیرفته شد."

msgid "Request rejected."
msgstr "درخواست رد شد."

msgid "Friend removed."
msgstr "دوست حذف شد."

msgid "You are now following this member."
msgstr "شما اکنون این عضو را دنبال می‌کنید."

msgid "You have unfollowed this member."
msgstr "دنبال کردن این عضو لغو شد."

msgid "User blocked."
msgstr "کاربر مسدود شد."

msgid "User unblocked."
msgstr "مسدودیت کاربر رفع شد."

msgid "Too many friend requests. Please wait."
msgstr "تعداد درخواست‌های دوستی زیاد است. لطفاً صبر کنید."

msgid "Group name is required."
msgstr "نام گروه الزامی است."

msgid "Failed to create group."
msgstr "ایجاد گروه ناموفق بود."

msgid "Group created!"
msgstr "گروه ایجاد شد!"

msgid "Group not found."
msgstr "گروه یافت نشد."

msgid "This group cannot be joined directly."
msgstr "این گروه قابل پیوستن مستقیم نیست."

msgid "You have joined the group."
msgstr "شما به گروه پیوستید."

msgid "Membership request sent."
msgstr "درخواست عضویت ارسال شد."

msgid "Only group members can invite others."
msgstr "فقط اعضای گروه می‌توانند دیگران را دعوت کنند."

msgid "User not found."
msgstr "کاربر یافت نشد."

msgid "Invitation sent."
msgstr "دعوت‌نامه ارسال شد."

msgid "You are the only admin. Assign another admin before leaving."
msgstr "شما تنها مدیر هستید. قبل از خروج، مدیر دیگری تعیین کنید."

msgid "You have left the group."
msgstr "شما از گروه خارج شدید."

msgid "Group deleted."
msgstr "گروه حذف شد."

msgid "You are sending messages too quickly. Please wait."
msgstr "شما خیلی سریع پیام ارسال می‌کنید. لطفاً صبر کنید."

msgid "Message cannot be empty."
msgstr "پیام نمی‌تواند خالی باشد."

msgid "Could not send message."
msgstr "ارسال پیام ناموفق بود."

msgid "Recipient required."
msgstr "گیرنده الزامی است."

msgid "Conversation deleted."
msgstr "مکالمه حذف شد."

msgid "New Message"
msgstr "پیام جدید"

msgid "%s sent you a friend request."
msgstr "%s درخواست دوستی برای شما ارسال کرد."

msgid "%s accepted your friend request."
msgstr "%s درخواست دوستی شما را پذیرفت."

msgid "%s mentioned you in an activity update."
msgstr "%s شما را در یک به‌روزرسانی ذکر کرد."

msgid "%s invited you to join a group."
msgstr "%s شما را به پیوستن به یک گروه دعوت کرد."

msgid "%s sent you a message."
msgstr "%s برای شما پیامی ارسال کرد."

msgid "%s reacted to your activity."
msgstr "%s به فعالیت شما واکنش نشان داد."

msgid "Your %s digest"
msgstr "خلاصه %s شما"

msgid "Here are your recent notifications:"
msgstr "اعلان‌های اخیر شما:"

msgid "Manage notification preferences"
msgstr "مدیریت تنظیمات اعلان"

msgid "Your account has been suspended. Please contact an administrator."
msgstr "حساب کاربری شما تعلیق شده است. لطفاً با مدیر تماس بگیرید."

msgid "Edit Profile"
msgstr "ویرایش پروفایل"

msgid "Change Photo"
msgstr "تغییر عکس"

msgid "Connect"
msgstr "ارتباط"

msgid "Profile sections"
msgstr "بخش‌های پروفایل"

msgid "No bio yet."
msgstr "بیوگرافی‌ای وجود ندارد."

msgid "Activity feed"
msgstr "جریان فعالیت"

msgid "Member directory"
msgstr "فهرست اعضا"

msgid "Search members…"
msgstr "جستجوی اعضا…"

msgid "Conversations"
msgstr "مکالمات"

msgid "Message thread"
msgstr "رشته پیام"

msgid "Select a conversation"
msgstr "یک مکالمه انتخاب کنید"

msgid "Type a message…"
msgstr "یک پیام بنویسید…"

msgid "Send"
msgstr "ارسال"

msgid "Friends"
msgstr "دوستان"

msgid "About"
msgstr "درباره"

msgid "Online"
msgstr "آنلاین"

msgid "Verified"
msgstr "تأیید شده"

msgid "Verified Member"
msgstr "عضو تأیید شده"

msgid "6Arshid Social Community requires PHP %s or higher."
msgstr "شبکه اجتماعی ۶ به PHP نسخه %s یا بالاتر نیاز دارد."

msgid "6Arshid Social Community requires WordPress %s or higher."
msgstr "شبکه اجتماعی ۶ به وردپرس نسخه %s یا بالاتر نیاز دارد."

msgid "Invitation Limit"
msgstr "محدودیت دعوت‌نامه"

msgid "Maximum invitations a member can send. 0 = unlimited."
msgstr "حداکثر تعداد دعوت‌نامه‌هایی که عضو می‌تواند ارسال کند. ۰ = نامحدود."

